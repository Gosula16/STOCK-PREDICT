# Shared secret for gateway ↔ orchestrator ↔ Next.js API proxy
API_SECRET=dev-change-me

# Next.js (frontend/.env.local)
GATEWAY_URL=http://localhost:3001

# NestJS gateway (optional local .env in gateway/)
# ORCHESTRATOR_URL=http://127.0.0.1:8000
# PORT=3001
# CORS_ORIGIN=http://localhost:3000

# Orchestrator (optional local .env in orchestrator/)
# REDIS_URL=redis://127.0.0.1:6379/0
# BROKER_MODE=paper
#
# Groww Trade API (JWT auth token from Groww — NOT the same as API_SECRET above)
# GROWW_AUTH_TOKEN=
# Exchange tokens from https://growwapi-assets.groww.in/instruments/instrument.csv
# GROWW_INSTRUMENTS_JSON=[{"exchange":"NSE","segment":"CASH","exchange_token":"2885","symbol":"RELIANCE"}]
# GROWW_LTP_WAIT_SECONDS=2
# Live broker writes: place / cancel / modify (off by default — real money at risk)
# GROWW_ALLOW_BROKER_MUTATIONS=false
# GROWW_ALLOW_PLACE_ORDER=false
# BROKER_MODE=live
#
# Risk caps (orchestrator)
# RISK_MAX_ORDER_QUANTITY=100
# RISK_MAX_ORDERS_PER_DAY=20
# RISK_MAX_NOTIONAL_PER_ORDER=0
# RISK_REQUIRE_LIMIT_PRICE=true
#
# Hugging Face Inference API (optional — revoke if leaked)
# HUGGINGFACE_API_TOKEN=
# HF_INFERENCE_MODEL=ProsusAI/finbert
# HF_ENABLE_IN_PIPELINE=false
# HF_MAX_SYMBOLS_PER_TICK=3
